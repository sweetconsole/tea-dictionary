generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Hieroglyph {
  id            Int    @id @default(autoincrement())
  hieroglyph    String @unique
  transcription String
  translate     String

  @@map("hieroglyphs")
}

model Tea {
  id          Int    @id @default(autoincrement())
  name        String @unique
  hieroglyphs String @unique
  translate   String

  @@map("tea")
}

